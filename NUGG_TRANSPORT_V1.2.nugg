   DB_ULN_ZTBREQUEST-ZEDQUERY = &lt;FS_UPDATE&gt;-ZEDQUERY.
   DB_ULN_ZTBREQUEST-ZEDQTRPCOD = &lt;FS_UPDATE&gt;-ZEDQTRPCOD.
