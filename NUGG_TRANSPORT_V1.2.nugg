    <textElement ID="I" KEY="REQ" ENTRY="@CX@" LENGTH="14 "/>
    <textElement ID="I" KEY="RVA" ENTRY="Demande Validée" LENGTH="25 "/>
    <textElement ID="I" KEY="S00" ENTRY="@5B@" LENGTH="14 "/>
    <textElement ID="I" KEY="TB1" ENTRY="Critères de sélection" LENGTH="42 "/>
    <textElement ID="I" KEY="TB3" ENTRY="Option de Visualisation" LENGTH="46 "/>
    <textElement ID="I" KEY="TCT" ENTRY="Contrôler" LENGTH="19 "/>
    <textElement ID="I" KEY="TDI" ENTRY="Afficher" LENGTH="18 "/>
