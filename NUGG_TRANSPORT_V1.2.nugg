    <textElement ID="I" KEY="BVA" ENTRY="Lot Validé" LENGTH="20 "/>
    <textElement ID="I" KEY="CRI" ENTRY="Critique" LENGTH="18 "/>
    <textElement ID="I" KEY="CTL" ENTRY="@38@" LENGTH="14 "/>
    <textElement ID="I" KEY="DIS" ENTRY="@Y2@" LENGTH="14 "/>
    <textElement ID="I" KEY="E00" ENTRY="@5C@" LENGTH="14 "/>
    <textElement ID="I" KEY="EXP" ENTRY="Express" LENGTH="17 "/>
    <textElement ID="I" KEY="HEA" ENTRY="Hiérarchie" LENGTH="20 "/>
    <textElement ID="I" KEY="I00" ENTRY="@5D@" LENGTH="14 "/>
    <textElement ID="I" KEY="ICR" ENTRY="@OJ@" LENGTH="14 "/>
    <textElement ID="I" KEY="IEX" ENTRY="@03@" LENGTH="14 "/>
    <textElement ID="I" KEY="ITK" ENTRY="@03@" LENGTH="14 "/>
    <textElement ID="I" KEY="ITO" ENTRY="@0V@" LENGTH="14 "/>
