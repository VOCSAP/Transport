   <exception CLSNAME="ZCL_TRANSPORT_BATCH_WORKFLOW" CMPNAME="GET_MS_WORK_AREA" SCONAME="CX_OS_OBJECT_NOT_FOUND" VERSION="1" LANGU="F" DESCRIPT="Exception services d&apos;objet" MTDTYPE="4" EDITORDER="1 "/>
   <source>method GET_MS_WORK_AREA.
***BUILD 090501
     &quot; returning RESULT
